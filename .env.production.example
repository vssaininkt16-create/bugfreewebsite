# ==========================================
# BugZero Cyber Solutions - Production Environment Variables
# ==========================================
# Copy this file to .env.production and fill in the values
# DO NOT commit .env.production to version control!

# ==========================================
# DATABASE CONFIGURATION (REQUIRED)
# ==========================================
# MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?options
# OR: mongodb://username:password@host:port/database?options
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bugzero_db?retryWrites=true&w=majority

# Database name (optional - defaults to 'bugzero_db')
DB_NAME=bugzero_db

# ==========================================
# CORS CONFIGURATION (REQUIRED FOR PRODUCTION)
# ==========================================
# Comma-separated list of allowed origins
# Format: "https://yourdomain.com,https://www.yourdomain.com"
# For local development: "http://localhost:3000"
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Node environment (production, development)
NODE_ENV=production

# ==========================================
# VERCEL-SPECIFIC (Auto-configured by Vercel)
# ==========================================
# VERCEL_URL=your-app.vercel.app (automatically set by Vercel)
# VERCEL_BRANCH_URL=your-branch.vercel.app (automatically set by Vercel)

# ==========================================
# DEBUGGING TIPS
# ==========================================
# If database connection fails:
# 1. Check that MONGODB_URI is correctly set in Vercel dashboard
# 2. Verify MongoDB Atlas network whitelist includes Vercel's IP ranges
# 3. Ensure SSL/TLS is enabled (mongodb+srv:// or ssl=true)
# 4. Check username/password are correct
#
# If CORS errors occur:
# 1. Verify ALLOWED_ORIGINS includes your production domain
# 2. Check for typos in the domain (no trailing slashes)
# 3. Ensure the origin matches exactly (www vs non-www)
#
# To enable debug logging locally:
# Set NODE_ENV=development in .env.local
